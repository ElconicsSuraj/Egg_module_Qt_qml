# Egg Measurement System - PyTorch Configuration
MODEL_PATH=media/best.pt
CALIBRATION_FILE=media/calibration_data.json

# Camera Settings
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_HEIGHT_MM=300

# Operational Mode
# Options: scale / measure / api / multi
CALIBRATION_MODE=api
# CALIBRATION_MODE=multi
API_PORT=8000
CPU_THREADS=0

# Measurement Tuning
EGG_LOSS_TIMEOUT_S=1.0
BATCH_SIZE=2
CONFIDENCE_THRESHOLD=0.20
BB_PADDING=50

# Calibration Controls
ENABLE_AUTO_EGG_CALIBRATION=True
ENABLE_CALIBRATION_CHECK=True
NUM_CALIBRATION_FRAMES=20

# UI & Logging
SHOW_DIAGNOSTIC_CIRCLE=true
LOG_LEVEL=INFO
MEASUREMENT_LOG_FILE=egg_measurements.txt